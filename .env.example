# ===========================================================================
# cloudflare-dns-mcp env — copy to the deploy env file and fill in the <…> values.
# Fail-closed by design: every token is validated, writes need a role + an allow-listed
# zone, delete is off, reads are fenced to the writable zones. There is NO unauth mode.
#
# IMPORTANT: this file is parsed by systemd EnvironmentFile=, which does NOT support
# inline comments. Every comment is on its own line; never put "# ..." after a value
# (the comment text would become part of the value). Replace EVERY <placeholder> — the
# server refuses to start if any required value is empty or still a <…>/REPLACE placeholder.
# ===========================================================================

# --- Cloudflare back end (the ONLY CF credential; account-scoped) ----------
# Scoped API token: DNS:Edit on the target account (Zone:Read optional). SECRET — 0640.
CFDNS_API_TOKEN=cfut_REPLACE_ME
CFDNS_ACCOUNT_ID=

# --- Writes: zone allow-list (create/edit/delete only touch these) ---------
# Zone NAMES or ids, comma-separated. EMPTY = writes disabled (read-only server).
CFDNS_EDIT_ZONES=your-zone.example
# delete_record is destructive (no undo) — off unless explicitly enabled.
CFDNS_ENABLE_DELETE=false
# Hard global kill-switch: true disables create/edit/delete outright, checked before the
# zone allow-list / role / rate-limit logic even runs. Set this for a read-only deployment
# instead of relying on CFDNS_EDIT_ZONES being empty (that's incidental, not declared intent).
CFDNS_READONLY=false

# --- Reads: fenced to the writable zones by default ------------------------
# Explicit read allow-list (names/ids). If empty, reads are fenced to CFDNS_EDIT_ZONES,
# unless CFDNS_ALLOW_ACCOUNT_READ=true (then reads span every zone the token can see).
CFDNS_READ_ZONES=
CFDNS_ALLOW_ACCOUNT_READ=false

# --- AuthN / AuthZ (all REQUIRED — tokens are always validated) ------------
# Front door validates the Entra bearer (JWKS sig, aud, iss, exp, scope, client).
# The tenant the app reg + turnstone live in.
CFDNS_TENANT_ID=<tenant-id>
# cloudflare-dns-mcp resource app client id (v2 tokens -> aud = this GUID).
CFDNS_CLIENT_ID=<resource-app-client-id>
# Optional audience override; CLIENT_ID and api://CLIENT_ID are auto-accepted.
CFDNS_AUDIENCE=
# Coarse "valid caller" scope. The NAME is arbitrary; it just has to match the app's scope.
CFDNS_REQUIRED_SCOPE=user_impersonation
# Only this client app (turnstone) may call — its appid/azp.
CFDNS_ALLOWED_CLIENTS=<turnstone-client-appid>
# Per-user authZ is the app-role claim: reads need the Dns.Read role, writes need Dns.Write.
# Assign users/groups to those roles on the resource app in Entra — there is no code knob.

# --- Service / operational -------------------------------------------------
# Per-operator write budget (create/edit/delete), sliding 60s window. 0 = unlimited.
CFDNS_WRITE_RATE_PER_MIN=30
CFDNS_PUBLIC_HOST=dns-mcp.example.com
CFDNS_PORT=8783
CFDNS_TIMEOUT=30
CFDNS_MAX_OUTPUT_CHARS=60000
CFDNS_MAX_PAGES=40
CFDNS_AUDIT_LOG=/opt/cloudflare-dns-mcp/var/audit.log
